# ⚠️ Firebaseコンソールからコピーした値を貼り付けてください
# 取得方法: セットアップ手順書 STEP 3 を参照

NEXT_PUBLIC_FIREBASE_API_KEY=ここにapiKeyを貼る
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ここにauthDomainを貼る
NEXT_PUBLIC_FIREBASE_DATABASE_URL=ここにdatabaseURLを貼る
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ここにprojectIdを貼る
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=ここにstorageBucketを貼る
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=ここにmessagingSenderIdを貼る
NEXT_PUBLIC_FIREBASE_APP_ID=ここにappIdを貼る
